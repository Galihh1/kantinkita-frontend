# ── App Config ───────────────────────────────────────────────
VITE_APP_NAME=KantinKita
VITE_APP_ENV=development

# ── API ──────────────────────────────────────────────────────
# Development: kosong atau http://localhost:8000 (Vite proxy handle /api)
# Production : ganti dengan Railway URL Anda
VITE_API_URL=http://localhost:8000

# ── Midtrans ─────────────────────────────────────────────────
# Sandbox untuk development, Production key untuk live
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx
VITE_MIDTRANS_SNAP_URL=https://app.sandbox.midtrans.com/snap/snap.js
